{
  "name": "prograds",
  "version": "0.0.0",
  "private": true,
  "description": "Taiwan graduate-exam prep hub: past papers, AI explanations, admissions info.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.34.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint . && turbo run lint",
    "lint:fix": "eslint . --fix && turbo run lint:fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fix": "prettier --write . && pnpm run lint:fix",
    "content": "prettier --write ../ProGrads-content && markdownlint-cli2 --fix \"../ProGrads-content/**/*.md\"",
    "content:check": "prettier --check ../ProGrads-content && markdownlint-cli2 \"../ProGrads-content/**/*.md\"",
    "sync": "pnpm --filter @prograds/content-sync sync",
    "db:refresh": "pnpm --filter @prograds/db db:deploy && pnpm --filter @prograds/db db:seed && pnpm run sync",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver",
      "vue-demi"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "@unhead/bundler>unhead": "2"
      }
    }
  }
}
