{
  "name": "@prograds/content-sync",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "tsx src/index.ts",
    "sync:prune": "tsx src/index.ts --prune",
    "validate": "tsx src/validate.ts",
    "validate-admissions": "tsx src/validate.ts admissions",
    "validate-questions": "tsx src/validate.ts questions",
    "validate-faculty": "tsx src/validate.ts faculty",
    "report-coverage": "tsx src/report-coverage.ts",
    "report-admissions": "tsx src/report-admissions.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.spec.ts\""
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prograds/db": "workspace:*",
    "@prograds/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "pg": "^8.22.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  }
}
