# Copy to .env and fill in values.
#
# DATABASE_URL: same as packages/db/.env — point at the local docker-compose Postgres.
DATABASE_URL="postgresql://prograds:prograds@localhost:5433/prograds?schema=public"

# CONTENT_DIR (required to sync real content): absolute path to the root of the content repo.
# Clone the private ProGrads-content repo and point here:
#   CONTENT_DIR="/path/to/ProGrads-content"
# Without this, content-sync will exit immediately with 0 files synced.
# CONTENT_DIR=
