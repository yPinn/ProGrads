{
  // Formatting: Prettier everywhere, ESLint --fix on save (Volar also claims .vue → pin Prettier).
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // Tooling
  "eslint.useFlatConfig": true,
  "eslint.workingDirectories": [{ "mode": "auto" }],
  "typescript.tsdk": "node_modules/typescript/lib",
  "files.eol": "\n",

  // Tailwind v4 is CSS-configured (no tailwind.config.*); point IntelliSense at the web app's
  // entry stylesheet so class completions/linting work in this monorepo.
  "tailwindCSS.experimental.configFile": {
    "apps/web/app/assets/css/main.css": "apps/web/**"
  },

  // Perf: don't let the file watcher churn on build output (gitignored dirs are already excluded
  // from search via search.useIgnoreFiles, but the watcher and Explorer are not).
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/node_modules/**": true,
    "**/.nuxt/**": true,
    "**/.output/**": true,
    "**/.nitro/**": true,
    "**/.turbo/**": true,
    "**/dist/**": true,
    "**/coverage/**": true
  },

  // Declutter the Explorer of generated output (display-only; tools still read these).
  "files.exclude": {
    "**/.turbo": true,
    "**/.nuxt": true,
    "**/.output": true,
    "**/.nitro": true,
    "**/dist": true,
    "**/coverage": true,
    "**/*.tsbuildinfo": true
  },

  // Search: skip deps, build output, and the huge committed lockfile / generated Prisma client.
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.nuxt": true,
    "**/.output": true,
    "**/.turbo": true,
    "**/coverage": true,
    "**/pnpm-lock.yaml": true,
    "packages/db/generated": true
  }
}
