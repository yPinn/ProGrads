engine-strict=true

# Nuxt modules (e.g. @nuxtjs/seo) dynamically installModule() their sub-modules,
# which Nuxt resolves from the project root. Hoist nuxt-related packages so pnpm's
# strict node_modules doesn't hide transitive modules like @nuxtjs/robots.
public-hoist-pattern[]=*nuxt*
public-hoist-pattern[]=*@nuxt/*
public-hoist-pattern[]=*@nuxtjs/*
