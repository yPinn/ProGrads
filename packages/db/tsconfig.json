{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2023"],
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "strict": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["index.ts", "generated/**/*.ts", "prisma/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
