// ProGrads data model. See docs/02-data-model.md.
// Dual axis: program_track (navigation) + subject (global shared question bank).

generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum LicenseStatus {
  national_exam // government work, freely reusable
  school_official // school-published, per-school terms
  unknown // not collected
}

enum AdmissionType {
  exam // 考試入學
  recommended // 推甄
  in_service // 在職專班
}

enum QuestionType {
  mc
  essay
  calc
  proof
  cloze
  listening
}

enum AnswerType {
  single_choice
  multi_choice
  numeric
  essay
  proof
}

enum ReviewStatus {
  ai_generated
  human_verified
  flagged
}

enum Confidence {
  high
  medium
  low
}

enum AdmissionEvent {
  registration_start
  registration_end
  written_exam
  interview
  result
}

// ---------- Taxonomy ----------

model Category {
  id        String         @id @default(cuid())
  slug      String         @unique
  name      String
  tracks    ProgramTrack[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ProgramTrack {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  subjects    TrackSubject[]
  departments Department[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([categoryId])
}

// Global shared subject library (reused across schools and tracks).
model Subject {
  id                     String                  @id @default(cuid())
  slug                   String                  @unique
  name                   String
  tracks                 TrackSubject[]
  knowledgePoints        KnowledgePoint[]
  examSubjects           ExamSubjectSubject[]
  questions              QuestionSubject[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  admissionRoundSubjects AdmissionRoundSubject[]
}

model TrackSubject {
  trackId   String
  subjectId String
  track     ProgramTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  subject   Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([trackId, subjectId])
  @@index([subjectId])
}

model KnowledgePoint {
  id        String                   @id @default(cuid())
  slug      String
  name      String
  subjectId String
  subject   Subject                  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    KnowledgePoint?          @relation("KnowledgePointTree", fields: [parentId], references: [id])
  children  KnowledgePoint[]         @relation("KnowledgePointTree")
  questions QuestionKnowledgePoint[]

  @@unique([subjectId, slug])
  @@index([parentId])
}

// ---------- Schools / exams ----------

model School {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  departments Department[]
  exams       Exam[]
  schedules   AdmissionSchedule[]
  stats       AdmissionStat[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model Department {
  id        String              @id @default(cuid())
  slug      String
  name      String
  schoolId  String
  school    School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  trackId   String?
  track     ProgramTrack?       @relation(fields: [trackId], references: [id])
  exams     Exam[]
  schedules AdmissionSchedule[]
  stats     AdmissionStat[]
  groups    AdmissionGroup[]
  metadata  Json?

  @@unique([schoolId, slug])
  @@index([trackId])
}

// One admission paper set for a (school, dept, year, admissionType, group).
model Exam {
  id               String          @id @default(cuid())
  schoolId         String
  departmentId     String
  year             Int
  admissionType    AdmissionType
  group            String          @default("") // 組別代號 (sync key, 來自路徑); empty = 不分組
  // 解析後的招生組身分 (sync 時以 (departmentId, code=group) 查得); null = 不分組或該組未建。
  // 刪組別不連帶刪已歸檔考卷 → SetNull。group 仍為冪等 upsert key, 此為 join 加速欄。
  admissionGroupId String?
  sourceUrl        String?
  licenseStatus    LicenseStatus   @default(unknown)
  school           School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  department       Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  admissionGroup   AdmissionGroup? @relation(fields: [admissionGroupId], references: [id], onDelete: SetNull)
  examSubjects     ExamSubject[]
  metadata         Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([schoolId, departmentId, year, admissionType, group])
  @@index([year])
  @@index([admissionGroupId])
}

// A paper/section within an exam; may bundle multiple subjects (合科卷).
model ExamSubject {
  id        String               @id @default(cuid())
  examId    String
  exam      Exam                 @relation(fields: [examId], references: [id], onDelete: Cascade)
  name      String // e.g. 資料結構與演算法
  sourceUrl String?
  subjects  ExamSubjectSubject[]
  questions Question[]
  metadata  Json?

  // (examId, name) is the idempotent upsert key for sync; also indexes examId.
  @@unique([examId, name])
}

model ExamSubjectSubject {
  examSubjectId String
  subjectId     String
  examSubject   ExamSubject @relation(fields: [examSubjectId], references: [id], onDelete: Cascade)
  subject       Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([examSubjectId, subjectId])
  @@index([subjectId])
}

model Question {
  id              String                   @id @default(cuid())
  externalId      String                   @unique // frontmatter question_id
  examSubjectId   String
  examSubject     ExamSubject              @relation(fields: [examSubjectId], references: [id], onDelete: Cascade)
  number          String // 題號, e.g. 3 / 3a
  order           Int                      @default(0) // reliable whole-paper ordering
  type            QuestionType
  contentMd       String
  points          Float?
  metadata        Json?
  choices         Choice[]
  explanation     Explanation?
  subjects        QuestionSubject[]
  knowledgePoints QuestionKnowledgePoint[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([examSubjectId])
}

// Granular practice mapping: a question to one-or-more subjects.
model QuestionSubject {
  questionId String
  subjectId  String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([questionId, subjectId])
  @@index([subjectId])
}

model Choice {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label      String // A / B / C
  contentMd  String
  isCorrect  Boolean  @default(false)

  @@unique([questionId, label])
}

// Cached standard answer (Claude offline). Separate from the original question.
model Explanation {
  id             String       @id @default(cuid())
  questionId     String       @unique
  question       Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  standardAnswer String
  answerType     AnswerType
  confidence     Confidence?
  modelUsed      String?
  samplesCount   Int          @default(1)
  reviewStatus   ReviewStatus @default(ai_generated)
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model QuestionKnowledgePoint {
  questionId       String
  knowledgePointId String
  question         Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  knowledgePoint   KnowledgePoint @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)

  @@id([questionId, knowledgePointId])
  @@index([knowledgePointId])
}

// ---------- Admissions (independent of exam papers) ----------

model AdmissionSchedule {
  id            String         @id @default(cuid())
  schoolId      String
  departmentId  String?
  admissionType AdmissionType
  year          Int
  event         AdmissionEvent
  date          DateTime
  sourceUrl     String?
  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  department    Department?    @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@index([schoolId, year])
  @@index([departmentId])
}

model AdmissionStat {
  id            String        @id @default(cuid())
  schoolId      String
  departmentId  String
  admissionType AdmissionType
  year          Int
  applicants    Int?
  quota         Int?
  admitted      Int?
  school        School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  department    Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([schoolId, departmentId, admissionType, year])
  @@index([departmentId])
}

// 招生組別: 報考單位 = 校×系所×組; 招生方式/名額/考科 掛勾於組。只存穩定身分 (department+code);
// 逐年事實 (考科/名額/日程) 另存於 (組,年) 記錄。不分組系所無此列 (缺列=單一招生)。
// 考卷以 exam.admissionGroupId 串接此 entity (sync 時依 code 解析)。admission_stat 仍待後續。
model AdmissionGroup {
  id           String           @id @default(cuid())
  departmentId String
  code         String // 組別代號: ASCII a/b/c/d（＝甲/乙/丙/丁 顯示）
  name         String           @default("") // 組別名稱, e.g. 數位積體電路與系統; 可空
  displayOrder Int              @default(0)
  sourceUrl    String?
  department   Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  rounds       AdmissionRound[]
  exams        Exam[]

  @@unique([departmentId, code])
  @@index([departmentId])
}

// 招生梯次: 一筆 = 某組 × 某年 × 某管道。年度變動事實的中樞 (名額掛此; 考科/日程為子表)。
// 不串 exam (考卷↔組別 為後續)。
model AdmissionRound {
  id               String                  @id @default(cuid())
  admissionGroupId String
  year             Int // 西元學年, e.g. 2026 = 115 學年度
  admissionType    AdmissionType
  quota            Int? // 名額: 分組存於此, 補 admission_stat 無 group 的洞
  applicants       Int?
  admitted         Int?
  sourceUrl        String? // 招生簡章連結
  group            AdmissionGroup          @relation(fields: [admissionGroupId], references: [id], onDelete: Cascade)
  events           AdmissionRoundEvent[]
  subjects         AdmissionRoundSubject[]

  @@unique([admissionGroupId, year, admissionType])
  @@index([admissionGroupId])
  @@index([year])
}

// 招生事件: 報名/考試/放榜 的日期時間 + 地點 (一對多)。
model AdmissionRoundEvent {
  id       String         @id @default(cuid())
  roundId  String
  event    AdmissionEvent
  at       DateTime
  location String?
  round    AdmissionRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId])
}

// 考科 spec: 該梯次規定考哪些科 (連 shared Subject 庫; 與考卷 ExamSubject 共用分類、用途不同)。
model AdmissionRoundSubject {
  roundId   String
  subjectId String
  note      String? // 備註, e.g. 二選一 / 合科
  round     AdmissionRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  subject   Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([roundId, subjectId])
  @@index([subjectId])
}

