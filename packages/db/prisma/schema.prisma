// ProGrads data model. See docs/02-data-model.md.
// Dual axis: program_track (navigation) + subject (global shared question bank).

generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum LicenseStatus {
  national_exam // government work, freely reusable
  school_official // school-published, per-school terms
  unknown // not collected
}

enum AdmissionType {
  exam // 考試入學
  recommended // 推甄
  in_service // 在職專班
}

enum QuestionType {
  mc
  essay
  calc
  proof
  cloze
  listening
}

enum AnswerType {
  single_choice
  multi_choice
  numeric
  essay
  proof
}

enum ReviewStatus {
  ai_generated
  human_verified
  flagged
}

enum Confidence {
  high
  medium
  low
}

enum AdmissionEvent {
  account_open // 取得繳費帳號 (報名前置)
  registration_start
  registration_end
  document_deadline // 審查資料上傳截止
  admit_card // 准考證列印
  written_exam
  shortlist // 公告參加面試名單
  interview
  result
  enrollment // 報到
}

enum AdmissionStatus {
  not_published
  published
  superseded
}

enum ExamMethod {
  written // 筆試
  review // 審查
  interview // 口試
}

// ---------- Taxonomy ----------

model Category {
  id        String         @id @default(cuid())
  slug      String         @unique
  name      String
  tracks    ProgramTrack[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ProgramTrack {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  subjects    TrackSubject[]
  departments Department[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([categoryId])
}

// Global shared subject library (reused across schools and tracks).
model Subject {
  id                     String                       @id @default(cuid())
  slug                   String                       @unique
  name                   String
  tracks                 TrackSubject[]
  knowledgePoints        KnowledgePoint[]
  examSubjects           ExamSubjectSubject[]
  questions              QuestionSubject[]
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  admissionRoundSubjects AdmissionRoundSubject[]
  admissionPaperSubjects AdmissionRoundPaperSubject[]
}

model TrackSubject {
  trackId   String
  subjectId String
  track     ProgramTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  subject   Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([trackId, subjectId])
  @@index([subjectId])
}

model KnowledgePoint {
  id        String                   @id @default(cuid())
  slug      String
  name      String
  subjectId String
  subject   Subject                  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    KnowledgePoint?          @relation("KnowledgePointTree", fields: [parentId], references: [id])
  children  KnowledgePoint[]         @relation("KnowledgePointTree")
  questions QuestionKnowledgePoint[]

  @@unique([subjectId, slug])
  @@index([parentId])
}

// ---------- Schools / exams ----------

model School {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  departments Department[]
  exams       Exam[]
  schedules   AdmissionSchedule[]
  stats       AdmissionStat[]
  seasons     AdmissionSeason[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model Department {
  id           String                  @id @default(cuid())
  slug         String
  name         String
  schoolId     String
  school       School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  trackId      String?
  track        ProgramTrack?           @relation(fields: [trackId], references: [id])
  examSubjects ExamSubjectDepartment[]
  schedules    AdmissionSchedule[]
  stats        AdmissionStat[]
  groups       AdmissionGroup[]
  metadata     Json?

  @@unique([schoolId, slug])
  @@index([trackId])
}

// A school's exam session: (school, year, admissionType). 卷脫離系所——共用卷只存一份;
// 「哪些系所考此卷」改掛 ExamSubject.departments (M:N)。卷↔招生組別 M:N 留待招生 pipeline。
model Exam {
  id            String        @id @default(cuid())
  schoolId      String
  year          Int
  admissionType AdmissionType
  school        School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  examSubjects  ExamSubject[]
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([schoolId, year, admissionType])
  @@index([year])
}

// 物理考卷 (去重單位): 一份卷 = (exam, slug)。合科卷綁多 subject;共用卷掛多 department (M:N)。
model ExamSubject {
  id            String                  @id @default(cuid())
  examId        String
  exam          Exam                    @relation(fields: [examId], references: [id], onDelete: Cascade)
  slug          String // 卷 slug (來自路徑, 含卷別如 dsa-a); (examId, slug) 為冪等 upsert key
  name          String // 顯示名, e.g. 資料結構與演算法(A); 不再唯一
  licenseStatus LicenseStatus           @default(unknown) // 授權為逐卷事實
  sourceUrl     String?
  subjects      ExamSubjectSubject[]
  departments   ExamSubjectDepartment[]
  questions     Question[]
  metadata      Json?

  @@unique([examId, slug])
}

// 卷↔系所 M:N: 共用卷被多系所採用 (來源 = 題目 frontmatter departments 的聯集)。
model ExamSubjectDepartment {
  examSubjectId String
  departmentId  String
  examSubject   ExamSubject @relation(fields: [examSubjectId], references: [id], onDelete: Cascade)
  department    Department  @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([examSubjectId, departmentId])
  @@index([departmentId])
}

model ExamSubjectSubject {
  examSubjectId String
  subjectId     String
  examSubject   ExamSubject @relation(fields: [examSubjectId], references: [id], onDelete: Cascade)
  subject       Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([examSubjectId, subjectId])
  @@index([subjectId])
}

model Question {
  id              String                   @id @default(cuid())
  externalId      String                   @unique // frontmatter question_id
  examSubjectId   String
  examSubject     ExamSubject              @relation(fields: [examSubjectId], references: [id], onDelete: Cascade)
  number          String // 題號, e.g. 3 / 3a
  order           Int                      @default(0) // reliable whole-paper ordering
  type            QuestionType
  contentMd       String
  points          Float?
  metadata        Json?
  choices         Choice[]
  explanation     Explanation?
  subjects        QuestionSubject[]
  knowledgePoints QuestionKnowledgePoint[]
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([examSubjectId])
}

// Granular practice mapping: a question to one-or-more subjects.
model QuestionSubject {
  questionId String
  subjectId  String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([questionId, subjectId])
  @@index([subjectId])
}

model Choice {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label      String // A / B / C
  contentMd  String
  isCorrect  Boolean  @default(false)

  @@unique([questionId, label])
}

// Cached standard answer (Claude offline). Separate from the original question.
model Explanation {
  id             String       @id @default(cuid())
  questionId     String       @unique
  question       Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  standardAnswer String
  answerType     AnswerType
  confidence     Confidence?
  modelUsed      String?
  samplesCount   Int          @default(1)
  reviewStatus   ReviewStatus @default(ai_generated)
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model QuestionKnowledgePoint {
  questionId       String
  knowledgePointId String
  question         Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  knowledgePoint   KnowledgePoint @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)

  @@id([questionId, knowledgePointId])
  @@index([knowledgePointId])
}

// ---------- Admissions (independent of exam papers) ----------

model AdmissionSchedule {
  id            String         @id @default(cuid())
  schoolId      String
  departmentId  String?
  admissionType AdmissionType
  year          Int
  event         AdmissionEvent
  date          DateTime
  sourceUrl     String?
  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  department    Department?    @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@index([schoolId, year])
  @@index([departmentId])
}

model AdmissionStat {
  id            String        @id @default(cuid())
  schoolId      String
  departmentId  String
  admissionType AdmissionType
  year          Int
  applicants    Int?
  quota         Int?
  admitted      Int?
  school        School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  department    Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([schoolId, departmentId, admissionType, year])
  @@index([departmentId])
}

// 招生組別: 報考單位 = 校×系所×組; 招生方式/名額/考科 掛勾於組。只存穩定身分 (department+code);
// 逐年事實 (考科/名額/日程) 另存於 (組,年) 記錄。不分組系所無此列 (缺列=單一招生)。
// 考卷以 exam.admissionGroupId 串接此 entity (sync 時依 code 解析)。admission_stat 仍待後續。
model AdmissionGroup {
  id           String           @id @default(cuid())
  departmentId String
  code         String // 組別代號: ASCII a/b/c/d（＝甲/乙/丙/丁 顯示）
  name         String           @default("") // 組別名稱, e.g. 數位積體電路與系統; 可空
  displayOrder Int              @default(0)
  sourceUrl    String?
  metadata     Json?
  department   Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  rounds       AdmissionRound[]

  @@unique([departmentId, code])
  @@index([departmentId])
}

// 招生梯次: 一筆 = 某組 × 某年 × 某管道。年度變動事實的中樞 (名額掛此; 考科/日程為子表)。
// 不串 exam (考卷↔組別 為後續)。
model AdmissionRound {
  id               String                  @id @default(cuid())
  admissionGroupId String
  year             Int // 西元學年, e.g. 2026 = 115 學年度
  admissionType    AdmissionType
  quota            Int? // 名額: 分組存於此, 補 admission_stat 無 group 的洞
  applicants       Int?
  admitted         Int?
  sourceUrl        String? // 招生簡章連結
  admissionCode    String? // 官方招生代碼, e.g. 8611
  applicantType    String? // 身分別, e.g. 一般生
  resultBatch      Int? // 放榜梯次
  methods          ExamMethod[] // 筆試/審查/口試
  calculator       Boolean? // 可用計算機
  writtenWeight    Int? // 筆試佔分 %
  interviewWeight  Int? // 面試佔分 %
  interviewAt      DateTime? // 該組面試日
  tiebreak         String[] // 同分參酌順序 (科目顯示名)
  metadata         Json?
  group            AdmissionGroup          @relation(fields: [admissionGroupId], references: [id], onDelete: Cascade)
  events           AdmissionRoundEvent[]
  subjects         AdmissionRoundSubject[]
  papers           AdmissionRoundPaper[]

  @@unique([admissionGroupId, year, admissionType])
  @@index([admissionGroupId])
  @@index([year])
}

// 招生事件: 報名/考試/放榜 的日期時間 + 地點 (一對多)。
model AdmissionRoundEvent {
  id       String         @id @default(cuid())
  roundId  String
  event    AdmissionEvent
  at       DateTime
  location String?
  round    AdmissionRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId])
}

// 考科 spec: 該梯次規定考哪些科 (連 shared Subject 庫; 與考卷 ExamSubject 共用分類、用途不同)。
model AdmissionRoundSubject {
  roundId   String
  subjectId String
  note      String? // 備註, e.g. 二選一 / 合科
  round     AdmissionRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  subject   Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([roundId, subjectId])
  @@index([subjectId])
}

// 招生季: 校級 (校×年×管道)。區A 校級事實: 報名費/狀態/公告日/事件/節次時間表 掛此。
// 事件由 round 上移至此 (校級不重複); round 只留組年度事實。AdmissionSchedule(legacy) 整併待後續。
model AdmissionSeason {
  id             String                 @id @default(cuid())
  schoolId       String
  year           Int // 西元學年
  admissionType  AdmissionType
  status         AdmissionStatus        @default(published)
  announcedAt    DateTime? // 公告日 = 新鮮度錨點
  applicationFee Int? // 報名費
  interviewFee   Int? // 口試費
  feeWaiver      String[] // 減免身分, e.g. low_income
  sourceUrl      String?
  metadata       Json?
  school         School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  events         AdmissionSeasonEvent[]
  slots          AdmissionExamSlot[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([schoolId, year, admissionType])
  @@index([year])
}

// 招生事件 (校級): 報名/筆試/放榜/報到 等。詞彙見 AdmissionEvent enum。
model AdmissionSeasonEvent {
  id       String          @id @default(cuid())
  seasonId String
  event    AdmissionEvent
  at       DateTime
  endAt    DateTime? // 跨日/區間結束
  location String?
  sequence Int? // 放榜梯次
  note     String?
  metadata Json?
  season   AdmissionSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId])
}

// 節次時間表 (校級): 某日第幾節的考試時段。系所考哪科哪節由 AdmissionRoundPaper.section 串接。
model AdmissionExamSlot {
  id        String          @id @default(cuid())
  seasonId  String
  date      DateTime
  period    Int // 節次
  startTime String // HH:MM
  endTime   String // HH:MM
  note      String?
  season    AdmissionSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId])
}

// 招生考卷 (該梯次的卷/科目組): 合科卷綁多 subject; section 接節次時間表。
model AdmissionRoundPaper {
  id       String                       @id @default(cuid())
  roundId  String
  name     String // 卷/科目顯示名, e.g. 軟體設計
  section  Int? // 節次 (接 AdmissionExamSlot)
  weight   Float? // 佔總分 %
  note     String?
  metadata Json?
  round    AdmissionRound               @relation(fields: [roundId], references: [id], onDelete: Cascade)
  subjects AdmissionRoundPaperSubject[]

  @@unique([roundId, name])
  @@index([roundId])
}

model AdmissionRoundPaperSubject {
  paperId   String
  subjectId String
  paper     AdmissionRoundPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  subject   Subject             @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([paperId, subjectId])
  @@index([subjectId])
}

