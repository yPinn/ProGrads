# Copy to .env and fill in. Never commit real secrets.

# --- Database (server, bind localhost only; docker-compose host port 5433) ---
DATABASE_URL="postgresql://prograds:password@127.0.0.1:5433/prograds?schema=public"

# --- Redis (cache / BullMQ) ---
REDIS_URL="redis://127.0.0.1:6379"

# --- API ---
PORT=8088
HOST=0.0.0.0
API_BASE_URL="https://api.example.com"
# Web app origin; also the allowed CORS origin on the API. Dev: http://localhost:3000
WEB_BASE_URL="https://app.example.com"
COOKIE_DOMAIN=".example.com"
JWT_SECRET="change-me"

# --- Web (apps/web; Nuxt reads NUXT_PUBLIC_*) ---
NUXT_PUBLIC_API_BASE_URL="http://localhost:8088/api/v1"
NUXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- AI: offline (content factory) ---
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-opus-4-8"

# --- AI: online (grounded augmentation) ---
GROQ_API_KEY=""

# --- Email (reminders) ---
RESEND_API_KEY=""

# --- Observability ---
SENTRY_DSN=""
